# 서버 전용 환경변수 예시.
# 실제 파일은 EC2 의 /home/ubuntu/baseball.env 로 두고 권한 600 (chmod 600).
# 절대 레포에 커밋하지 말 것 (.env.example 만 커밋).
#
#   cp baseball.env.example /home/ubuntu/baseball.env
#   chmod 600 /home/ubuntu/baseball.env
#   # 값 채운 뒤 sudo systemctl restart baseball

